{
  "name": "Enclave Messenger — Flutter Dev",
  "image": "ghcr.io/cirruslabs/flutter:stable",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.flutter",
        "Dart-Code.dart-code",
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "dart.flutterSdkPath": "/flutter"
      }
    }
  },
  "postCreateCommand": "cd gui/flutter && flutter pub get",
  "forwardPorts": [8000, 8080]
}
